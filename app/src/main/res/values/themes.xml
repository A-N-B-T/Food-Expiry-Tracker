<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.MyApplication.Launch" parent="Theme.MyApplication" />

    <style name="Theme.MyApplication.Launch.Light" parent="Theme.MyApplication.Launch">
        <item name="android:windowBackground">@color/launch_background_light</item>
    </style>

    <style name="Theme.MyApplication.Launch.Dark" parent="Theme.MyApplication.Launch">
        <item name="android:windowBackground">@color/launch_background_dark</item>
    </style>
</resources>
